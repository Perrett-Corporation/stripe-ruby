<!DOCTYPE html>
<html>
<head>
  <title>New SAR - Regulatory Portal</title>
  <style>
    body { font-family: sans-serif; padding: 20px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { padding: 10px; border: 1px solid #ddd; text-align: left; }
    th { background-color: #f4f4f4; }
    .btn { padding: 10px 15px; text-decoration: none; border: none; border-radius: 3px; color: white; cursor: pointer; }
    .btn-primary { background-color: #007bff; }
  </style>
</head>
<body>
  <h1>Create Suspicious Activity Report (SAR)</h1>

  <div style="background-color: #e8f4fd; padding: 15px; border-radius: 5px; margin-bottom: 20px; border: 1px solid #b8daff;">
    <h3>Start from Open Investigation (Intelligent Draft)</h3>
    <p>Select an ongoing case to auto-populate the SAR with subject data, risk profiles, and narratives.</p>
    <ul>
      <% @open_cases.each do |kase| %>
        <li>
            <strong><%= kase[:id] %></strong>: <%= kase[:subject_name] %>
            <span style="font-size: 0.8em; background-color: #eee; padding: 2px 5px; border-radius: 3px;"><%= kase[:status] %></span>
            <span style="color: red; font-size: 0.8em;">Risk: <%= kase[:risk_level] %></span>
            <br>
            <span style="font-size: 0.9em; color: gray;"><%= kase[:notes] %></span>
            <br>
            <a href="/sar/draft/<%= kase[:id] %>" class="btn btn-primary" style="font-size: 0.8em; padding: 3px 8px; margin-top: 5px; display: inline-block;">Auto-Draft SAR</a>
        </li>
      <% end %>
    </ul>
  </div>

  <p>Or manually select transactions:</p>

  <form action="/sar/create" method="post">
    <table>
      <thead>
        <tr>
          <th>Select</th>
          <th>ID</th>
          <th>Amount</th>
          <th>Date</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% @transactions.each do |tx| %>
          <tr>
            <td><input type="checkbox" name="transactions[]" value="<%= tx[:id] %>" checked></td>
            <td><%= tx[:id] %></td>
            <td><%= tx[:amount] %> <%= tx[:currency].upcase %></td>
            <td><%= Time.at(tx[:created]) %></td>
            <td><%= tx[:suspicion_reason] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div style="margin-top: 20px;">
      <button type="submit" class="btn btn-primary">Generate Report</button>
      <a href="/" style="margin-left: 10px;">Cancel</a>
    </div>
  </form>
</body>
</html>
