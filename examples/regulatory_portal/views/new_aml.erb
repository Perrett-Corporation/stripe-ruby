<!DOCTYPE html>
<html>
<head>
  <title>New AML Review - Regulatory Portal</title>
  <style>
    body { font-family: sans-serif; padding: 20px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { padding: 10px; border: 1px solid #ddd; text-align: left; }
    th { background-color: #f4f4f4; }
    .btn { padding: 10px 15px; text-decoration: none; border: none; border-radius: 3px; color: white; cursor: pointer; }
    .btn-primary { background-color: #007bff; }
  </style>
</head>
<body>
  <h1>Create Anti-Money Laundering (AML) Review</h1>
  <p>Review and select flagged transactions for this period:</p>

  <form action="/aml/create" method="post">
    <table>
      <thead>
        <tr>
          <th>Select</th>
          <th>ID</th>
          <th>Amount</th>
          <th>Date</th>
          <th>Risk Score</th>
        </tr>
      </thead>
      <tbody>
        <% @transactions.each do |tx| %>
          <tr>
            <td><input type="checkbox" name="transactions[]" value="<%= tx[:id] %>" checked></td>
            <td><%= tx[:id] %></td>
            <td><%= tx[:amount] %> <%= tx[:currency].upcase %></td>
            <td><%= Time.at(tx[:created]) %></td>
            <td style="color: <%= tx[:risk_score] > 80 ? 'red' : 'orange' %>"><%= tx[:risk_score] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div style="margin-top: 20px;">
      <button type="submit" class="btn btn-primary">Generate AML Report</button>
      <a href="/" style="margin-left: 10px;">Cancel</a>
    </div>
  </form>
</body>
</html>
